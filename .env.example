# Financial Document Q&A configuration
# Copy this file to .env. Do not commit .env.

# Runtime environment: development | production
ENVIRONMENT=development
DEBUG=false

# Local storage
CHROMA_DB_PATH=./data/chroma_db
UPLOAD_DIR=./data/uploads

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit
STREAMLIT_PORT=8501

# Embeddings are always generated locally with all-MiniLM-L6-v2.
# No API key is required for embeddings.

# HuggingFace Inference API (free) — for LLM-generated answers
# Get your token at huggingface.co -> Settings -> Access Tokens
# Leave HF_TOKEN empty to use extractive (no-LLM) fallback instead.
HF_TOKEN=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3
